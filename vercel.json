{
  "rewrites": [
    {
      "source": "/((?!_next|static|api|assets|.*\\..*).*)",
      "destination": "/api/index"
    },
    {
      "source": "/~oauth/(.*)",
      "destination": "/api/index"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
