/* ---------------- Dashboard ---------------- */

function Dashboard({
  tenders,
  goTo,
  openTender,
}: {
  tenders: TenderRecord[];
  goTo: (v: View) => void;
  openTender: (t: TenderRecord) => void;
}) {
  const stats = useMemo(() => {
    const total = tenders.length;
    const avg = total ? tenders.reduce((a, b) => a + b.average, 0) / total : 0;
    const high = tenders.filter((t) => t.riskLevel === "Alto" || t.riskLevel === "Crítico").length;
    const low = tenders.filter((t) => t.riskLevel === "Bajo").length;
    return { total, avg, high, low };
  }, [tenders]);

  return (
    <div className="space-y-8">
      <div
        className="rounded-2xl p-7 md:p-9 text-white relative overflow-hidden shadow-lg"
        style={{ background: "var(--gradient-primary)" }}
      >
        <div className="absolute -right-20 -top-20 w-72 h-72 rounded-full bg-white/10 blur-3xl" />
        <div className="relative max-w-2xl">
          <div className="text-xs uppercase tracking-widest opacity-80 mb-2">Plataforma SIEL</div>
          <h2 className="text-2xl md:text-3xl font-display font-bold leading-tight">
            Gestiona y evalúa tus licitaciones con criterios objetivos
          </h2>
          <p className="text-sm md:text-base opacity-90 mt-3">
            Sube el pliego, aplica la Matriz de 13 puntos y obtén un puntaje de riesgo automatizado para decidir con seguridad.
          </p>
          <div className="flex flex-wrap gap-3 mt-6">
            <button
              onClick={() => goTo("upload")}
              className="px-5 py-2.5 rounded-lg bg-white text-primary font-semibold text-sm hover:bg-white/95 transition shadow-md"
            >
              Subir pliego
            </button>
            <button
              onClick={() => goTo("matrix")}
              className="px-5 py-2.5 rounded-lg bg-white/10 border border-white/30 text-white font-semibold text-sm hover:bg-white/20 transition"
            >
              Nueva evaluación
            </button>
          </div>
        </div>
      </div>

      <div className="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <StatCard label="Licitaciones analizadas" value={stats.total.toString()} icon={FileText} tone="primary" />
        <StatCard label="Puntaje promedio" value={stats.avg ? stats.avg.toFixed(2) : "—"} icon={TrendingUp} tone="primary" />
        <StatCard label="Riesgo alto / crítico" value={stats.high.toString()} icon={AlertTriangle} tone="warning" />
        <StatCard label="Riesgo bajo" value={stats.low.toString()} icon={CheckCircle2} tone="success" />
      </div>

      <div className="grid lg:grid-cols-3 gap-6">
        <div className="lg:col-span-2 bg-card rounded-2xl border border-border shadow-sm">
          <div className="p-5 border-b border-border flex items-center justify-between">
            <div>
              <h3 className="font-display font-semibold">Últimas evaluaciones</h3>
              <p className="text-xs text-muted-foreground mt-0.5">Las 5 licitaciones más recientes.</p>
            </div>
            <button
              onClick={() => goTo("history")}
              className="text-xs font-semibold text-primary hover:underline"
            >
              Ver todo →
            </button>
          </div>
          <div className="p-2">
            {tenders.length === 0 ? (
              <EmptyState
                title="Aún no hay licitaciones"
                message="Sube tu primer pliego para empezar a evaluar."
                cta="Subir pliego"
                onCta={() => goTo("upload")}
              />
            ) : (
              <ul className="divide-y divide-border">
                {tenders.slice(0, 5).map((t) => (
                  <li key={t.id}>
                    <button
                      onClick={() => openTender(t)}
                      className="w-full text-left px-3 py-3.5 hover:bg-muted/50 rounded-lg transition flex items-center gap-4"
                    >
                      <div className="h-10 w-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
                        <Building2 className="h-5 w-5" />
                      </div>
                      <div className="flex-1 min-w-0">
                        <div className="font-semibold text-sm truncate">{t.name}</div>
                        <div className="text-xs text-muted-foreground truncate">{t.entity}</div>
                      </div>
                      <div className="text-right">
                        <div className="text-sm font-bold">{t.average.toFixed(2)}</div>
                        <span className={`text-[10px] px-2 py-0.5 rounded-full border font-semibold ${riskColor(t.riskLevel)}`}>
                          {t.riskLevel}
                        </span>
                      </div>
                    </button>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>

        <div className="bg-card rounded-2xl border border-border shadow-sm p-5">
          <h3 className="font-display font-semibold">Distribución de riesgo</h3>
          <p className="text-xs text-muted-foreground mt-0.5 mb-4">Categorías presentes en tu historial.</p>
          <RiskDistribution tenders={tenders} />
        </div>
      </div>
    </div>
  );
}

function StatCard({
  label,
  value,
  icon: Icon,
  tone,
}: {
  label: string;
  value: string;
  icon: typeof LayoutDashboard;
  tone: "primary" | "success" | "warning";
}) {
  const toneClass =
    tone === "success"
      ? "bg-success/10 text-success"
      : tone === "warning"
      ? "bg-warning/30 text-warning-foreground"
      : "bg-primary/10 text-primary";
  return (
    <div className="bg-card rounded-2xl border border-border p-5 shadow-sm">
      <div className={`h-9 w-9 rounded-lg flex items-center justify-center ${toneClass}`}>
        <Icon className="h-4.5 w-4.5" />
      </div>
      <div className="mt-4 text-2xl font-display font-bold">{value}</div>
      <div className="text-xs text-muted-foreground mt-0.5">{label}</div>
    </div>
  );
}

function RiskDistribution({ tenders }: { tenders: TenderRecord[] }) {
  const levels: Array<{ key: TenderRecord["riskLevel"]; color: string }> = [
    { key: "Bajo", color: "bg-success" },
    { key: "Medio", color: "bg-primary" },
    { key: "Alto", color: "bg-warning" },
    { key: "Crítico", color: "bg-destructive" },
  ];
  const total = tenders.length || 1;
  return (
    <div className="space-y-3">
      {levels.map((l) => {
        const count = tenders.filter((t) => t.riskLevel === l.key).length;
        const pct = (count / total) * 100;
        return (
          <div key={l.key}>
            <div className="flex items-center justify-between text-xs mb-1.5">
              <span className="font-semibold">{l.key}</span>
              <span className="text-muted-foreground">{count} · {pct.toFixed(0)}%</span>
            </div>
            <div className="h-2 bg-muted rounded-full overflow-hidden">
              <div className={`h-full ${l.color} transition-all`} style={{ width: `${pct}%` }} />
            </div>
          </div>
        );
      })}
    </div>
  );
}

function EmptyState({ title, message, cta, onCta }: { title: string; message: string; cta?: string; onCta?: () => void }) {
  return (
    <div className="py-12 text-center">
      <div className="mx-auto h-12 w-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-3">
        <FileText className="h-6 w-6" />
      </div>
      <div className="font-semibold">{title}</div>
      <div className="text-sm text-muted-foreground mt-1">{message}</div>
      {cta && onCta && (
        <button onClick={onCta} className="mt-4 px-4 py-2 rounded-lg bg-primary text-primary-foreground text-sm font-semibold hover:opacity-90">
          {cta}
        </button>
      )}
    </div>
  );
}

/* ---------------- Upload ---------------- */

function UploadSection({
  file,
  setFile,
  continueToMatrix,
}: {
  file: File | null;
  setFile: (f: File | null) => void;
  continueToMatrix: () => void;
}) {
  const inputRef = useRef<HTMLInputElement>(null);
  const [drag, setDrag] = useState(false);

  const handleFiles = (files: FileList | null) => {
    if (!files || !files[0]) return;
    const f = files[0];
    if (f.type !== "application/pdf" && !f.name.toLowerCase().endsWith(".pdf")) {
      alert("Por favor sube un archivo PDF.");
      return;
    }
    if (f.size > 20 * 1024 * 1024) {
      alert("El archivo supera los 20 MB.");
      return;
    }
    setFile(f);
  };

  return (
    <div className="max-w-3xl mx-auto space-y-6">
      <div
        onDragOver={(e) => { e.preventDefault(); setDrag(true); }}
        onDragLeave={() => setDrag(false)}
        onDrop={(e) => { e.preventDefault(); setDrag(false); handleFiles(e.dataTransfer.files); }}
        onClick={() => inputRef.current?.click()}
        className={`cursor-pointer rounded-2xl border-2 border-dashed p-10 md:p-14 text-center bg-card transition ${
          drag ? "border-primary bg-primary/5" : "border-border hover:border-primary/50"
        }`}
      >
        <div className="mx-auto h-14 w-14 rounded-2xl flex items-center justify-center text-white shadow-md" style={{ background: "var(--gradient-primary)" }}>
          <FileUp className="h-7 w-7" />
        </div>
        <h3 className="mt-5 font-display font-semibold text-lg">Arrastra el pliego aquí</h3>
        <p className="text-sm text-muted-foreground mt-1">o haz clic para seleccionar un archivo PDF (máx. 20 MB).</p>
        <input
          ref={inputRef}
          type="file"
          accept="application/pdf"
          className="hidden"
          onChange={(e) => handleFiles(e.target.files)}
        />
      </div>

      {file && (
        <div className="bg-card rounded-2xl border border-border p-5 shadow-sm flex items-center gap-4">
          <div className="h-12 w-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
            <FileText className="h-6 w-6" />
          </div>
          <div className="flex-1 min-w-0">
            <div className="font-semibold truncate">{file.name}</div>
            <div className="text-xs text-muted-foreground">{(file.size / 1024).toFixed(1)} KB · PDF</div>
          </div>
          <button onClick={() => setFile(null)} className="p-2 rounded-lg hover:bg-muted text-muted-foreground">
            <X className="h-4 w-4" />
          </button>
          <button
            onClick={continueToMatrix}
            className="px-4 py-2 rounded-lg bg-primary text-primary-foreground text-sm font-semibold hover:opacity-90"
          >
            Continuar a la matriz →
          </button>
        </div>
      )}

      <div className="bg-secondary/60 rounded-2xl p-5 text-sm text-secondary-foreground">
        <div className="font-semibold mb-1">💡 Recomendación</div>
        El archivo se conserva durante esta sesión para asociarlo a la evaluación. Para guardarlo permanentemente, activa el almacenamiento en la nube.
      </div>
    </div>
  );
}

/* ---------------- Matrix Form ---------------- */

function MatrixForm({
  uploadedFile,
  onSave,
}: {
  uploadedFile: File | null;
  onSave: (t: TenderRecord) => void;
}) {
  const [meta, setMeta] = useState({ name: "", entity: "", amount: "", deadline: "", notes: "" });
  const [scores, setScores] = useState<Record<number, number>>(defaultScores);
  const [weights, setWeights] = useState<Record<number, number>>(defaultWeights);
  const [itemNotes, setItemNotes] = useState<Record<number, string>>(defaultItemNotes);

  const total = useMemo(() => Object.values(scores).reduce((a, b) => a + b, 0), [scores]);
  const average = total / MATRIX_ITEMS.length;
  const weightSum = useMemo(
    () => Object.values(weights).reduce((a, b) => a + (Number(b) || 0), 0),
    [weights],
  );
  const weighted = useMemo(() => computeWeighted(scores, weights), [scores, weights]);
  const risk = classifyRisk(weighted);
  const reco = computeRecommendation(weighted);
  const weightsValid = Math.round(weightSum) === 100;

  const submit = () => {
    if (!meta.name.trim() || !meta.entity.trim()) {
      alert("Completa al menos el nombre de la licitación y la entidad.");
      return;
    }
    if (!weightsValid) {
      alert(`Los pesos deben sumar 100%. Actualmente suman ${weightSum.toFixed(1)}%.`);
      return;
    }
    const record: TenderRecord = {
      id: crypto.randomUUID(),
      name: meta.name.trim(),
      entity: meta.entity.trim(),
      amount: meta.amount.trim(),
      deadline: meta.deadline,
      fileName: uploadedFile?.name ?? null,
      scores,
      weights,
      itemNotes,
      total,
      average,
      weighted,
      riskLevel: risk,
      recommendation: reco,
      notes: meta.notes.trim(),
      createdAt: new Date().toISOString(),
    };
    onSave(record);
  };

  const resetWeights = () => setWeights(defaultWeights());

  return (
    <div className="grid lg:grid-cols-[1fr_340px] gap-6">
      <div className="space-y-6">
        <section className="bg-card rounded-2xl border border-border shadow-sm p-6">
          <div className="flex items-center gap-2 mb-1">
            <span className="h-6 w-6 rounded-md bg-primary/10 text-primary text-xs font-bold flex items-center justify-center">1</span>
            <h3 className="font-display font-semibold">Información General del Proceso</h3>
          </div>
          <p className="text-xs text-muted-foreground mb-4 ml-8">Entidad, objeto, presupuesto, modalidad, plazos y datos clave del proceso.</p>
          <div className="grid md:grid-cols-2 gap-4">
            <Field label="Nombre / objeto de la licitación *">
              <input className={inputCls} value={meta.name} onChange={(e) => setMeta({ ...meta, name: e.target.value })} placeholder="Ej. Construcción vía urbana — LP-2025-014" />
            </Field>
            <Field label="Entidad contratante *">
              <input className={inputCls} value={meta.entity} onChange={(e) => setMeta({ ...meta, entity: e.target.value })} placeholder="Ej. Alcaldía de Medellín" />
            </Field>
            <Field label="Presupuesto oficial">
              <input className={inputCls} value={meta.amount} onChange={(e) => setMeta({ ...meta, amount: e.target.value })} placeholder="Ej. $ 1.250.000.000" />
            </Field>
            <Field label="Fecha límite">
              <input type="date" className={inputCls} value={meta.deadline} onChange={(e) => setMeta({ ...meta, deadline: e.target.value })} />
            </Field>
          </div>
          {uploadedFile && (
            <div className="mt-4 flex items-center gap-2 text-xs text-muted-foreground">
              <FileText className="h-4 w-4 text-primary" />
              Pliego asociado: <span className="font-medium text-foreground">{uploadedFile.name}</span>
            </div>
          )}
        </section>

        <section className="bg-card rounded-2xl border border-border shadow-sm">
          <div className="p-5 border-b border-border flex items-center justify-between gap-3 flex-wrap">
            <div>
              <div className="text-[11px] uppercase tracking-widest text-primary font-bold">Matriz de evaluación</div>
              <h3 className="font-display font-semibold mt-0.5">13 componentes profesionales</h3>
              <p className="text-xs text-muted-foreground mt-0.5">Califica de 1 a 5, ajusta el peso porcentual y agrega notas por componente.</p>
            </div>
            <div className="flex items-center gap-3">
              <div className={`text-xs font-semibold px-3 py-1.5 rounded-lg border ${weightsValid ? "text-success bg-success/10 border-success/30" : "text-destructive bg-destructive/10 border-destructive/30"}`}>
                Pesos: {weightSum.toFixed(1)}% / 100%
              </div>
              <button onClick={resetWeights} type="button" className="text-xs font-semibold text-primary hover:underline">
                Restablecer pesos
              </button>
            </div>
          </div>
          <div className="divide-y divide-border">
            {MATRIX_ITEMS.map((it) => (
              <div key={it.id} className="p-5 md:p-6 space-y-4">
                <div className="grid lg:grid-cols-[1fr_auto] gap-4 items-start">
                  <div>
                    <div className="flex items-center gap-2">
                      <span className="h-6 w-6 rounded-md bg-primary/10 text-primary text-xs font-bold flex items-center justify-center">{it.id}</span>
                      <div className="font-semibold text-sm">{it.title}</div>
                    </div>
                    <p className="text-xs text-muted-foreground mt-1.5 ml-8">{it.description}</p>
                  </div>
                  <div className="flex items-end gap-3 ml-8 lg:ml-0">
                    <Field label="Calificación (1-5)">
                      <ScorePicker value={scores[it.id]} onChange={(v) => setScores({ ...scores, [it.id]: v })} />
                    </Field>
                    <Field label="Peso %">
                      <input
                        type="number"
                        min={0}
                        max={100}
                        step={0.5}
                        value={weights[it.id]}
                        onChange={(e) => setWeights({ ...weights, [it.id]: Number(e.target.value) })}
                        className={`${inputCls} w-24 text-center`}
                      />
                    </Field>
                  </div>
                </div>
                <div className="ml-0 md:ml-8">
                  <Field label="Notas">
                    <textarea
                      rows={2}
                      className={`${inputCls} resize-none`}
                      value={itemNotes[it.id]}
                      onChange={(e) => setItemNotes({ ...itemNotes, [it.id]: e.target.value })}
                      placeholder="Observaciones, evidencias o riesgos detectados…"
                    />
                  </Field>
                </div>
              </div>
            ))}
          </div>
        </section>
      </div>

      <aside className="lg:sticky lg:top-28 lg:self-start space-y-4">
        <div className="bg-card rounded-2xl border border-border shadow-sm overflow-hidden">
          <div className="p-5 text-white" style={{ background: "var(--gradient-primary)" }}>
            <div className="text-xs uppercase tracking-widest opacity-80">Resultado</div>
            <div className="mt-1 font-display font-bold text-2xl">Puntaje ponderado</div>
            <div className="mt-2 text-4xl font-display font-bold">{weighted.toFixed(1)}<span className="text-lg opacity-80">/100</span></div>
          </div>
          <div className="p-5 space-y-4">
            <div className="grid grid-cols-2 gap-3">
              <Metric label="Promedio" value={average.toFixed(2)} />
              <Metric label="Total bruto" value={`${total}/${MATRIX_ITEMS.length * 5}`} />
              <Metric label="Clasificación" value={risk} />
              <Metric label="Recomendación" value={reco} />
            </div>

            <div>
              <div className="text-xs font-semibold mb-1.5 text-muted-foreground">Nivel de riesgo</div>
              <div className="relative h-3 rounded-full bg-muted overflow-hidden flex">
                <div className="h-full bg-destructive" style={{ width: "46%" }} />
                <div className="h-full bg-warning" style={{ width: "20%" }} />
                <div className="h-full bg-primary" style={{ width: "18%" }} />
                <div className="h-full bg-success" style={{ width: "16%" }} />
              </div>
              <div className="relative h-0">
                <div
                  className="absolute -top-4 h-5 w-0.5 bg-foreground"
                  style={{ left: `${Math.min(100, Math.max(0, weighted))}%` }}
                />
              </div>
              <div className="mt-2 flex justify-between text-[10px] text-muted-foreground font-medium">
                <span>Crítico</span><span>Alto</span><span>Medio</span><span>Bajo</span>
              </div>
            </div>

            <div className={`rounded-lg border px-3 py-2.5 text-sm font-semibold text-center ${riskColor(risk)}`}>
              Riesgo {risk} · {reco}
            </div>
          </div>
        </div>

        <Field label="Conclusión general">
          <textarea
            rows={4}
            className={`${inputCls} resize-none`}
            value={meta.notes}
            onChange={(e) => setMeta({ ...meta, notes: e.target.value })}
            placeholder="Notas o conclusiones del análisis…"
          />
        </Field>

        <button
          onClick={submit}
          disabled={!weightsValid}
          className="w-full py-3 rounded-xl bg-primary text-primary-foreground font-semibold text-sm hover:opacity-90 shadow-md transition disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Guardar evaluación
        </button>
        {!weightsValid && (
          <p className="text-xs text-destructive text-center">Ajusta los pesos para que sumen exactamente 100%.</p>
        )}
      </aside>
    </div>
  );
}


const inputCls =
  "w-full px-3.5 py-2.5 rounded-lg border border-input bg-background text-sm placeholder:text-muted-foreground/70 focus:outline-none focus:ring-2 focus:ring-ring/40 focus:border-ring transition";

function Field({ label, children }: { label: string; children: React.ReactNode }) {
  return (
    <label className="block">
      <span className="block text-xs font-semibold text-muted-foreground mb-1.5">{label}</span>
      {children}
    </label>
  );
}

function Metric({ label, value }: { label: string; value: string }) {
  return (
    <div className="rounded-lg bg-secondary/60 px-3 py-2.5">
      <div className="text-[10px] uppercase tracking-wider text-muted-foreground font-semibold">{label}</div>
      <div className="font-display font-bold text-base mt-0.5">{value}</div>
    </div>
  );
}

function ScorePicker({ value, onChange }: { value: number; onChange: (v: number) => void }) {
  return (
    <div className="flex items-center gap-1.5">
      {[1, 2, 3, 4, 5].map((n) => (
        <button
          key={n}
          type="button"
          onClick={() => onChange(n)}
          className={`h-10 w-10 rounded-lg text-sm font-bold border transition ${
            value === n
              ? "bg-primary text-primary-foreground border-primary shadow-md scale-105"
              : "bg-background border-border text-muted-foreground hover:border-primary/50 hover:text-primary"
          }`}
        >
          {n}
        </button>
      ))}
    </div>
  );
}

/* ---------------- History ---------------- */

function HistorySection({
  tenders,
  onDelete,
  selected,
  setSelected,
}: {
  tenders: TenderRecord[];
  onDelete: (id: string) => void;
  selected: TenderRecord | null;
  setSelected: (t: TenderRecord | null) => void;
}) {
  const [q, setQ] = useState("");
  const [riskFilter, setRiskFilter] = useState<string>("Todos");

  const filtered = tenders.filter((t) => {
    const matchQ = !q || `${t.name} ${t.entity}`.toLowerCase().includes(q.toLowerCase());
    const matchR = riskFilter === "Todos" || t.riskLevel === riskFilter;
    return matchQ && matchR;
  });

  return (
    <div className="space-y-5">
      <div className="bg-card rounded-2xl border border-border shadow-sm p-4 flex flex-col md:flex-row gap-3 md:items-center">
        <div className="relative flex-1">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
          <input
            value={q}
            onChange={(e) => setQ(e.target.value)}
            placeholder="Buscar por nombre o entidad…"
            className={`${inputCls} pl-9`}
          />
        </div>
        <div className="flex gap-2">
          {["Todos", "Bajo", "Medio", "Alto", "Crítico"].map((r) => (
            <button
              key={r}
              onClick={() => setRiskFilter(r)}
              className={`px-3 py-2 rounded-lg text-xs font-semibold border transition ${
                riskFilter === r ? "bg-primary text-primary-foreground border-primary" : "bg-background border-border hover:border-primary/40"
              }`}
            >
              {r}
            </button>
          ))}
        </div>
      </div>

      <div className="bg-card rounded-2xl border border-border shadow-sm overflow-hidden">
        {filtered.length === 0 ? (
          <EmptyState title="Sin resultados" message="No hay licitaciones que coincidan con los filtros." />
        ) : (
          <div className="overflow-x-auto">
            <table className="w-full text-sm">
              <thead className="bg-muted/60 text-xs uppercase tracking-wider text-muted-foreground">
                <tr>
                  <th className="text-left px-5 py-3 font-semibold">Licitación</th>
                  <th className="text-left px-5 py-3 font-semibold hidden md:table-cell">Entidad</th>
                  <th className="text-left px-5 py-3 font-semibold hidden lg:table-cell">Presupuesto</th>
                  <th className="text-left px-5 py-3 font-semibold hidden lg:table-cell">Fecha</th>
                  <th className="text-center px-5 py-3 font-semibold">Puntaje</th>
                  <th className="text-center px-5 py-3 font-semibold">Riesgo</th>
                  <th className="px-5 py-3"></th>
                </tr>
              </thead>
              <tbody className="divide-y divide-border">
                {filtered.map((t) => (
                  <tr key={t.id} className="hover:bg-muted/40 transition">
                    <td className="px-5 py-3.5">
                      <button onClick={() => setSelected(t)} className="text-left">
                        <div className="font-semibold">{t.name}</div>
                        <div className="text-xs text-muted-foreground md:hidden">{t.entity}</div>
                      </button>
                    </td>
                    <td className="px-5 py-3.5 hidden md:table-cell text-muted-foreground">{t.entity}</td>
                    <td className="px-5 py-3.5 hidden lg:table-cell text-muted-foreground">{t.amount || "—"}</td>
                    <td className="px-5 py-3.5 hidden lg:table-cell text-muted-foreground">
                      {t.deadline ? new Date(t.deadline).toLocaleDateString() : "—"}
                    </td>
                    <td className="px-5 py-3.5 text-center font-bold">{t.average.toFixed(2)}</td>
                    <td className="px-5 py-3.5 text-center">
                      <span className={`inline-block text-[11px] px-2.5 py-1 rounded-full border font-semibold ${riskColor(t.riskLevel)}`}>
                        {t.riskLevel}
                      </span>
                    </td>
                    <td className="px-5 py-3.5 text-right">
                      <button
                        onClick={() => { if (confirm("¿Eliminar esta licitación?")) onDelete(t.id); }}
                        className="p-1.5 rounded-md text-muted-foreground hover:text-destructive hover:bg-destructive/10"
                        aria-label="Eliminar"
                      >
                        <Trash2 className="h-4 w-4" />
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      {selected && <DetailDrawer tender={selected} onClose={() => setSelected(null)} />}
    </div>
  );
}

function DetailDrawer({ tender, onClose }: { tender: TenderRecord; onClose: () => void }) {
  return (
    <div className="fixed inset-0 z-50 flex justify-end">
      <div className="absolute inset-0 bg-foreground/30 backdrop-blur-sm" onClick={onClose} />
      <div className="relative w-full max-w-xl bg-card h-full overflow-y-auto shadow-2xl">
        <div className="p-6 border-b border-border flex items-start justify-between gap-4">
          <div className="min-w-0">
            <div className="text-[11px] uppercase tracking-widest text-primary font-bold">Detalle</div>
            <h3 className="font-display font-bold text-lg mt-1">{tender.name}</h3>
            <div className="text-sm text-muted-foreground">{tender.entity}</div>
          </div>
          <button onClick={onClose} className="p-2 rounded-lg hover:bg-muted">
            <X className="h-4 w-4" />
          </button>
        </div>

        <div className="p-6 space-y-5">
          <div className="grid grid-cols-2 gap-3">
            <Metric label="Ponderado" value={`${tender.weighted.toFixed(1)}/100`} />
            <Metric label="Promedio" value={tender.average.toFixed(2)} />
            <Metric label="Riesgo" value={tender.riskLevel} />
            <Metric label="Recomendación" value={tender.recommendation ?? "—"} />
          </div>

          <div className="text-xs text-muted-foreground space-y-1">
            {tender.amount && <div><span className="font-semibold text-foreground">Presupuesto:</span> {tender.amount}</div>}
            {tender.deadline && <div><span className="font-semibold text-foreground">Fecha límite:</span> {new Date(tender.deadline).toLocaleDateString()}</div>}
            {tender.fileName && <div><span className="font-semibold text-foreground">Pliego:</span> {tender.fileName}</div>}
            <div><span className="font-semibold text-foreground">Registrada:</span> {new Date(tender.createdAt).toLocaleString()}</div>
          </div>

          <div>
            <h4 className="font-display font-semibold mb-2">Matriz de 13 puntos</h4>
            <ul className="divide-y divide-border border border-border rounded-xl overflow-hidden">
              {MATRIX_ITEMS.map((it) => {
                const note = tender.itemNotes?.[it.id];
                const weight = tender.weights?.[it.id] ?? it.weight;
                return (
                  <li key={it.id} className="px-4 py-3 text-sm">
                    <div className="flex items-center gap-3">
                      <span className="h-6 w-6 rounded-md bg-primary/10 text-primary text-xs font-bold flex items-center justify-center shrink-0">{it.id}</span>
                      <span className="flex-1 truncate">{it.title}</span>
                      <span className="text-[10px] text-muted-foreground font-semibold tabular-nums">{weight}%</span>
                      <span className="font-bold tabular-nums w-10 text-right">{tender.scores[it.id]}/5</span>
                    </div>
                    {note && <p className="text-xs text-muted-foreground mt-1.5 ml-9 whitespace-pre-wrap">{note}</p>}
                  </li>
                );
              })}
            </ul>
          </div>


          {tender.notes && (
            <div>
              <h4 className="font-display font-semibold mb-1.5">Observaciones</h4>
              <p className="text-sm text-muted-foreground whitespace-pre-wrap">{tender.notes}</p>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
