import { createFileRoute } from "@tanstack/react-router";
import { useEffect, useMemo, useRef, useState } from "react";
import {
  LayoutDashboard,
  FileUp,
  ClipboardList,
  History,
  ShieldCheck,
  TrendingUp,
  AlertTriangle,
  CheckCircle2,
  FileText,
  Trash2,
  X,
  Search,
  Building2,
} from "lucide-react";
import {
  MATRIX_ITEMS,
  TOTAL_WEIGHT,
  type TenderRecord,
  classifyRisk,
  computeWeighted,
  defaultItemNotes,
  defaultScores,
  defaultWeights,
  loadTenders,
  recommendation as computeRecommendation,
  riskColor,
  saveTenders,
} from "@/lib/matrix";

export const Route = createFileRoute("/")({
  head: () => ({
    meta: [
      { title: "SIEL — Panel de Licitaciones" },
      { name: "description", content: "Panel central de SIEL para subir pliegos, evaluar la Matriz de 13 puntos y consultar el historial de licitaciones." },
    ],
  }),
  component: SielApp,
});

type View = "dashboard" | "upload" | "matrix" | "history";

function SielApp() {
  const [view, setView] = useState<View>("dashboard");
  const [tenders, setTenders] = useState<TenderRecord[]>([]);
  const [uploadedFile, setUploadedFile] = useState<File | null>(null);
  const [selected, setSelected] = useState<TenderRecord | null>(null);

  useEffect(() => {
    setTenders(loadTenders());
  }, []);

  const persist = (next: TenderRecord[]) => {
    setTenders(next);
    saveTenders(next);
  };

  const addTender = (t: TenderRecord) => persist([t, ...tenders]);
  const removeTender = (id: string) => persist(tenders.filter((t) => t.id !== id));

  return (
    <div className="flex min-h-screen bg-background font-sans text-foreground">
      <Sidebar view={view} setView={setView} />
      <main className="flex-1 min-w-0">
        <Topbar view={view} />
        <div className="px-5 md:px-10 py-8 max-w-[1400px] mx-auto">
          {view === "dashboard" && (
            <Dashboard tenders={tenders} goTo={setView} openTender={(t) => { setSelected(t); setView("history"); }} />
          )}
          {view === "upload" && (
            <UploadSection
              file={uploadedFile}
              setFile={setUploadedFile}
              continueToMatrix={() => setView("matrix")}
            />
          )}
          {view === "matrix" && (
            <MatrixForm
              uploadedFile={uploadedFile}
              onSave={(record) => {
                addTender(record);
                setUploadedFile(null);
                setView("history");
              }}
            />
          )}
          {view === "history" && (
            <HistorySection
              tenders={tenders}
              onDelete={removeTender}
              selected={selected}
              setSelected={setSelected}
            />
          )}
        </div>
      </main>
    </div>
  );
}

/* ---------------- Sidebar ---------------- */

